# Environment Variables - Lumis Backend
# Copy this file to .env.local and fill in the real values

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lumis_db?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ── Email (OTP) ───────────────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Lumis Platform <no-reply@lumis.edu.vn>"

# ── OpenAI (AI Chat + Embeddings) ─────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ── Cloud Storage (AWS S3 or GCS) ─────────────────────────────────────────────
STORAGE_PROVIDER="s3"          # "s3" | "gcs"
AWS_REGION="ap-southeast-1"
AWS_BUCKET_NAME="lumis-documents"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="your-secret"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OTP_EXPIRES_MINUTES=10
